{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RVO Event Schema",
  "description": "Schema for realtime video orchestration events written to events.jsonl",
  "type": "object",
  "required": [
    "event_type",
    "event_ts_ns",
    "confidence"
  ],
  "properties": {
    "event_type": {
      "type": "string",
      "description": "Confirmed temporal event type"
    },
    "event_ts_ns": {
      "type": "integer",
      "minimum": 0,
      "description": "Event timestamp in nanoseconds"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Detection confidence score"
    }
  },
  "additionalProperties": true
}
